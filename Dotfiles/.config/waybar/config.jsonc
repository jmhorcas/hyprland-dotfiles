{
    "layer": "top",
    //"mode": "dock",
    "exclusive": true,
    "passthrough": false,
    "position": "top",
    "spacing": 3,
    "fixed-center": true,
    "ipc": true,
    "margin-top": 3,
    "margin-left": 8,
    "margin-right": 8,

    "modules-left": ["hyprland/window"],
    "modules-center": ["group/notify",
                       "custom/separator#dot-line",
                       "hyprland/workspaces#rw",
                       "custom/separator#dot-line",
                       "clock", 
                       "custom/separator#dot-line",
                       "custom/weather"],
    "modules-right": ["tray", 
		      "custom/separator#dot-line",
                      "group/mobo_drawer", 
		      "custom/separator#dot-line",
		      "group/audio",
		      "custom/separator#dot-line",
                      "battery", 
                      "custom/separator#dot-line",
                      "custom/power"],

    "group/notify": {
        "orientation": "inherit",
        "drawer": {
            "transition-duration": 500,
            "children-class": "custom/swaync",
            "transition-left-to-right": false
            },
        "modules": [
            "custom/swaync",
            "custom/updater",
        ]
    },
    "custom/swaync": {
        "tooltip": true,
        "tooltip-format": "Left Click: Launch Notification Center\nRight Click: Do not Disturb",
        "format": "{} {icon} ",
        "format-icons": {
            "notification": "’éó<span foreground='red'><sup>’æä</sup></span>",
            "none": "’éó",
            "dnd-notification": "’ćĘ<span foreground='red'><sup>’æä</sup></span>",
            "dnd-none": "’ćĘ",
            "inhibited-notification": "’éó<span foreground='red'><sup>’æä</sup></span>",
            "inhibited-none": "’éó",
            "dnd-inhibited-notification": "’ćĘ<span foreground='red'><sup>’æä</sup></span>",
            "dnd-inhibited-none": "’ćĘ"
        },
        "return-type": "json",
        "exec-if": "which swaync-client",
        "exec": "swaync-client -swb",
        "on-click": "sleep 0.1 && swaync-client -t -sw",
        "on-click-right": "swaync-client -d -sw",
        "escape": true,
    },
    "custom/updater": {
        "format": "’ĆÖ {}",
        "exec": "checkupdates | wc -l",
        "exec-if": "[[ $(checkupdates | wc -l) ]]",
        "interval": 43200, // (Arch Linux will try to check 12 hrs interval only
        "on-click": "$HOME/.config/hypr/scripts/Distro_update.sh",
        "tooltip": true,
        "tooltip-format": "Left Click: Update System",
    },
    "clock": {
        "interval": 1,
        //"format": "’ĆŚ {:%I:%M %p}", // AM PM format
        "format": "’ĆŚ {:%H:%M}", // 24H
        "format-alt": "’ĆŚ {:L%H:%M  ’ü│ %Y, %d %B, %A}",
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "calendar": {
            "mode": "year",
            "mode-mon-col": 3,
            "weeks-pos": "right",
            "on-scroll": 1,
            "format": {
                "months": "<span color='#ffead3'><b>{}</b></span>",
                "days": "<span color='#ecc6d9'><b>{}</b></span>",
                "weeks": "<span color='#99ffdd'><b>W{:%V}</b></span>",
                "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
                "today": "<span color='#ff6699'><b><u>{}</u></b></span>"
            }
        }
    },
    "custom/weather": {
        "format": "{}",
        "format-alt": "{alt}: {}",
        "format-alt-click": "click",
        "interval": 3600,
        "return-type": "json",
        "exec": "$HOME/.config/hypr/scripts/WeatherWrap.sh",
        "tooltip": true,
    },
    "battery": {
        "states": { "warning": 30, "critical": 15 },
        "format": "{icon} {capacity}%",
        "format-icons": ["’ēä", "’ēā", "’ēé", "’ēü", "’ēĆ"]
    },

    "custom/power": {
        "format": "ŌÅ╗", // Puedes usar "’Ćæ " si tienes Nerd Fonts instalada
        "on-click": "wlogout", // O la ruta a tu script: "~/.config/hypr/scripts/Wlogout.sh"
        "tooltip": "Logout menu"
    },
    "hyprland/workspaces#rw": {
        "disable-scroll": true,
        "all-outputs": true,
        "warp-on-scroll": false,
        "sort-by-number": true,
        "show-special": false,
        "on-click": "activate",
        "on-scroll-up": "hyprctl dispatch workspace e+1",
        "on-scroll-down": "hyprctl dispatch workspace e-1",
        "persistent-workspaces": {
            "*": 5
        },
        "format": "{icon} {windows}",
        "format-window-separator": " ",
        "window-rewrite-default": "’üÖ ",
        "window-rewrite": {		
            "title<.*amazon.*>": "’ē░ ",
            "title<.*reddit.*>": "’Ŗü ",

            "class<firefox|org.mozilla.firefox|librewolf|floorp|mercury-browser|[Cc]achy-browser>": "ŅØģ ",
            "class<zen>": "¾░░Ę ",
            "class<waterfox|waterfox-bin>": "Ņ║ō ",
            "class<microsoft-edge>": "’Ŗé ",
            "class<Chromium|Thorium|[Cc]hrome>": "’ē© ",
            "class<brave-browser>": "­¤”ü ",
            "class<tor browser>": "’Ź▒ ",
            "class<firefox-developer-edition>": "­¤”Ŗ ",

            "class<kitty|konsole|[Aa]lacritty>": "Ņ»å ",
            "class<kitty-dropterm>": "’äĀ ",
            "class<com.mitchellh.ghostty>": " Ņ×Ģ",
            "class<org.wezfurlong.wezterm>": " Ņ¬ģ",
            "class<Warp|warp|dev.warp.Warp|warp-terminal>": "¾░░Ł ",

            "class<[Tt]hunderbird|[Tt]hunderbird-esr>": "’Ź░ ",
            "class<eu.betterbird.Betterbird>": "’Ź░ ",
            "title<.*gmail.*>": "¾░Ŗ½ ",

            "class<[Tt]elegram-desktop|org.telegram.desktop|io.github.tdesktop_x64.TDesktop>": "ŅłŚ ",
            "class<discord|discord-canary|[Ww]ebcord|[Vv]esktop|com.discordapp.Discord|dev.vencord.Vesktop>": "’ć┐ ",
            "class<[Ss]ignal|signal-desktop|org.signal.Signal>": "¾░Ź® ",
            "title<.*Signal.*>": "¾░Ź® ",
            "title<.*whatsapp.*>": "’ł▓ ",
            "title<.*zapzap.*>": "’ł▓ ",
            "title<.*messenger.*>": "’ē¤ ",
            "title<.*facebook.*>": "’éÜ ",
            "title<.*Discord.*>": "’ć┐ ",

            "title<.*ChatGPT.*>": "¾░Ü® ",
            "title<.*deepseek.*>": "¾░Ü® ",
            "title<.*qwen.*>": "¾░Ü® ",
            "class<subl>": "¾░ģ│ ",
            "class<slack>": "’åś ",

            "class<mpv>": "’Ź« ",
            "class<celluloid|Zoom>": "’ĆĮ ",
            "class<Cider>": "¾░Äå ",
            "title<.*Picture-in-Picture.*>": "’ö¼ ",
            "title<.*youtube.*>": "’ģ¬ ",
            "class<vlc>": "¾░Ģ╝ ",
            "class<[Kk]denlive|org.kde.kdenlive>": "­¤Ä¼ ",
            "title<.*Kdenlive.*>": "­¤Ä¼ ",
            "title<.*cmus.*>": "’Ćü ",
            "class<[Ss]potify>": "’å╝ ",
            "class<Plex>": "¾░Ü║ ",

            "class<virt-manager>": "ŅŁ╗ ",
            "class<.virt-manager-wrapped>": "ŅŁ╗ ",
            "class<remote-viewer|virt-viewer>": "ŅŁ╗ ",
            "class<virtualbox manager>": "­¤ÆĮ ",
            "title<virtualbox>": "­¤ÆĮ ",
            "class<remmina|org.remmina.Remmina>": "­¤¢ź’ĖÅ ",

            "class<VSCode|code|code-url-handler|code-oss|codium|codium-url-handler|VSCodium>": "¾░©× ",
            "class<dev.zed.Zed>": "¾░Ąü",
            "class<codeblocks>": "¾░ģ® ",
            "title<.*github.*>": "’äō ",
            "class<mousepad>": "’ģ£ ",
            "class<libreoffice-writer>": "ŅÜź ",
            "class<libreoffice-startcenter>": "¾░Åå ",
            "class<libreoffice-calc>": "’Ź╗ ",
            "title<.*nvim ~.*>": "’Ź» ",
            "title<.*vim.*>": "Ņ¤ģ ",
            "title<.*nvim.*>": "Ņ¤ģ ",
            "title<.*figma.*>": "ŅĮć ",
            "title<.*jira.*>": "ŅØ£ ",
            "class<jetbrains-idea>": "Ņ×Ą ",

            "class<obs|com.obsproject.Studio>": "Ņ«¦ ",

            "class<polkit-gnome-authentication-agent-1>": "¾░Æā ",
            "class<nwg-look>": "ŅŁÆ ",
            "class<nwg-displays>": "’ē¼ ",
            "class<[Pp]avucontrol|org.pulseaudio.pavucontrol>": "¾▒Ī½ ",
            "class<steam>": "’åČ ",
            "class<thunar|nemo>": "¾░Ø░ ",	
            "class<Gparted>":"’āć",
            "class<gimp>": "’īĖ ",
            "class<emulator>": "­¤ō▒ ",
            "class<android-studio>": "’ģ╗ ",
            "class<org.pipewire.Helvum>": "¾░ōā",
            "class<localsend>":"’ćĀ",
            "class<PrusaSlicer|UltiMaker-Cura|OrcaSlicer>": "¾░╣ø",

            "class<io.github.kolunmi.Bazaar>": "’Ŗæ ",
            "title<^Bazaar$>": "’Ŗæ ",

            "class<com.gabm.satty>": "’Ć░ ",
            "title<^satty$>": "’Ć░ ",

            "class<[Bb]ox[Bb]uddy|io.github.dvlv.boxbuddy|io.github.dvlv.BoxBuddy>": "’å▓ ",
            "title<.*BoxBuddy.*>": "’å▓ ",

            "title<Hyprland Keybinds>": "’ä£ ",
            "title<Niri Keybinds>": "’ä£ ",
            "title<BSPWM Keybinds>": "’ä£ ",
            "title<DWM Keybinds>": "’ä£ ",
            "title<Emacs Leader Keybinds>": "’ä£ ",
            "title<Kitty Configuration>": "’ä£ ",
            "title<WezTerm Configuration>": "’ä£ ",
            "title<Yazi Configuration>": "’ä£ ",
            "title<Cheatsheets Viewer>": "’ĆŁ ",
            "title<Documentation Viewer>": "’āČ ",
            "title<^Wallpapers$>": "’ĆŠ ",
            "title<^Video Wallpapers$>": "’ĆĮ ",
            "title<^qs-wlogout$>": "’éŗ ",
        }
	},
    "custom/separator#dot-line": {
        "format": "ŅśĪ",
        "interval": "once",
        "tooltip": false
    },
	"tray": {
	    "icon-size": 18,
	    "spacing": 10
	},

"group/mobo_drawer": {
	"orientation": "inherit",
	"drawer": {
		"transition-duration": 500,
		"children-class": "cpu",
		"transition-left-to-right": true
        },
	"modules": [
		"cpu",		
		"temperature",
		"power-profiles-daemon",	
		"memory",
		"disk",
	]
},

"group/audio": {
	"orientation": "inherit",
	"drawer": {
		"transition-duration": 500,
		"children-class": "pulseaudio",
		"transition-left-to-right": true
        },
	"modules": [
		"pulseaudio",
		"pulseaudio#microphone",
	]
},

"pulseaudio": {
	"format": "{icon} {volume}%",
	"format-bluetooth": "{icon} ¾░é░ {volume}%",
	"format-muted": "¾░¢ü",
	"format-icons": {
		"headphone": "’Ćź",
		"hands-free": "’Ćź",
		"headset": "’¢É",
		"phone": "’éĢ",
		"portable": "’éĢ",
		"car": "’å╣",
		"default": [
			"’Ć”", "’Ć¦", "¾░ĢŠ",  "’Ć©"
		],
		"ignored-sinks": [
			"Easy Effects Sink"
		],
	},
	"scroll-step": 5.0,
	"on-click": "$HOME/.config/hypr/scripts/Volume.sh --toggle",
	"on-click-right": "pavucontrol -t 3",
	"on-scroll-up": "$HOME/.config/hypr/scripts/Volume.sh --inc",
	"on-scroll-down": "$HOME/.config/hypr/scripts/Volume.sh --dec",
	"tooltip-format": "{icon} {desc} | {volume}%",
	"smooth-scrolling-threshold": 1,
},

"pulseaudio#1": {
  "format": "{icon} {volume}%",
  "format-bluetooth": "{icon}’Ŗö {volume}%",
  "format-bluetooth-muted": "’Ü® {icon}’Ŗö",
  "format-muted": "¾░Ėł",
  "format-icons": {
      "headphone": "’¢É",
      "hands-free": "’Ćź",
      "headset": "’¢É",
      "phone": "’éĢ",
      "portable": "’éĢ",
      "car": "’å╣",
      "default": ["’Ć”", "’Ć¦", "’Ć©"]
    },
  "on-click": "pamixer --toggle-mute",
  "on-click-right": "pavucontrol -t 3",
  "tooltip": true,
  "tooltip-format": "{icon} {desc} | {volume}%",
},

"pulseaudio#microphone": {
	"format": "{format_source}",
	"format-source": "’ä░ {volume}%",
	"format-source-muted": "’ä▒",
	"on-click": "$HOME/.config/hypr/scripts/Volume.sh --toggle-mic",
	"on-click-right": "pavucontrol -t 4",
	"on-scroll-up": "$HOME/.config/hypr/scripts/Volume.sh --mic-inc",
	"on-scroll-down": "$HOME/.config/hypr/scripts/Volume.sh --mic-dec",
	"tooltip-format": "{source_desc} | {source_volume}%",
	"scroll-step": 5,
},

"temperature": {
	"interval": 10,
	"tooltip": true,
	"hwmon-path": [
		"/sys/class/hwmon/hwmon1/temp1_input",
		"/sys/class/thermal/thermal_zone0/temp"
	],
	//"thermal-zone": 0,
	"critical-threshold": 82,
	"format-critical": "{temperatureC}┬░C {icon}",
	"format": "{temperatureC}┬░C {icon}",
	"format-icons": [
		"¾░łĖ"
	],
	"on-click-right": "$HOME/.config/hypr/scripts/WaybarScripts.sh --nvtop"
},
"cpu": {
	"format": "{usage}% ¾░Źø",
	"interval": 1,
	"min-length": 5,
	"format-alt-click": "click",
	"format-alt": "{icon0}{icon1}{icon2}{icon3} {usage:>2}% ¾░Źø",
	"format-icons": [
		"Ō¢ü", "Ō¢é", "Ō¢ā", "Ō¢ä", "Ō¢ģ", "Ō¢å", "Ō¢ć", "Ō¢ł"
	],
	"on-click-right": "kitty --class btop_floating -e btop",
},
"power-profiles-daemon": {
  "format": "{icon} ",
  "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
  "tooltip": true,
  "format-icons": {
    "default": "’ā¦",
    "performance": "’ā¦",
    "balanced": "’ēÄ",
    "power-saver": "’ü¼"
  }
},
"memory": {
	"interval": 10,
	"format": "{used:0.1f}G ¾░Šå",
	"format-alt": "{percentage}% ¾░Šå",
	"format-alt-click": "click",
	"tooltip": true,
	"tooltip-format": "{used:0.1f}GB/{total:0.1f}G",
	"on-click-right": "$HOME/.config/hypr/scripts/WaybarScripts.sh --btop"
},
"disk": {
	"interval": 30,
	//"format": "¾░ŗŖ",
	"path": "/",
	//"format-alt-click": "click",
	"format": "{percentage_used}% ¾░ŗŖ",
	//"tooltip": true,
	"tooltip-format": "{used} used out of {total} on {path} ({percentage_used}%)",
},
}

