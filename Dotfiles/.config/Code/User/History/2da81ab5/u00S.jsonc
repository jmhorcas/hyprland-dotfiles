            "class<codeblocks>": "¾░à® ",
            "title<.*github.*>": "´äô ",
            "class<mousepad>": "´à£ ",
            "class<libreoffice-writer>": "¯ÜÑ ",
            "class<libreoffice-startcenter>": "¾░Åå ",
            "class<libreoffice-calc>": "´ì╗ ",
            "title<.*nvim ~.*>": "´ì» ",
            "title<.*vim.*>": "¯ƒà ",
            "title<.*nvim.*>": "¯ƒà ",
