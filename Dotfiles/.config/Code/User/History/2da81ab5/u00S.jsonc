            "class<android-studio>": "´à╗ ",
            "class<org.pipewire.Helvum>": "¾░ôâ",
            "class<localsend>":"´çá",
            "class<PrusaSlicer|UltiMaker-Cura|OrcaSlicer>": "¾░╣ø",

            "class<io.github.kolunmi.Bazaar>": "´èæ ",
            "title<^Bazaar$>": "´èæ ",

            "class<com.gabm.satty>": "´Ç░ ",
            "title<^satty$>": "´Ç░ ",

            "class<[Bb]ox[Bb]uddy|io.github.dvlv.boxbuddy|io.github.dvlv.BoxBuddy>": "´å▓ ",
