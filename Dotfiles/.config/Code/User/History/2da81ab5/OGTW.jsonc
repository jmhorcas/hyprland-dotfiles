            "class<VSCode|code|code-url-handler|code-oss|codium|codium-url-handler|VSCodium>": "¾░©× ",
            "class<dev.zed.Zed>": "¾░Ąü",
            "class<codeblocks>": "¾░ģ® ",
            "title<.*github.*>": "’äō ",
            "class<mousepad>": "’ģ£ ",
            "class<libreoffice-writer>": "ŅÜź ",
