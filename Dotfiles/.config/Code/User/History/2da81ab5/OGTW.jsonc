            "class<Gparted>":"’āć",
            "class<gimp>": "’īĖ ",
            "class<emulator>": "­¤ō▒ ",
            "class<android-studio>": "’ģ╗ ",
            "class<org.pipewire.Helvum>": "¾░ōā",
            "class<localsend>":"’ćĀ",
            "class<PrusaSlicer|UltiMaker-Cura|OrcaSlicer>": "¾░╣ø",

            "class<io.github.kolunmi.Bazaar>": "’Ŗæ ",
