{
    "layer": "top",
    "position": "top", // Puede ser bottom, left, right
    //"height": 30,      // Altura en pГӯxeles
    
    "modules-left": ["hyprland/window"],
    "modules-center": ["hyprland/workspaces#rw", "clock", "custom/weather"],
    "modules-right": ["network", "cpu", "memory", "battery", "tray", "custom/power"],

    "clock": {
        "interval": 1,
        //"format": "пҖ— {:%I:%M %p}", // AM PM format
        "format": "пҖ— {:%H:%M}", // 24H
        "format-alt": "пҖ— {:L%H:%M  пҒі %Y, %d %B, %A}",
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "calendar": {
            "mode": "year",
            "mode-mon-col": 3,
            "weeks-pos": "right",
            "on-scroll": 1,
            "format": {
                "months": "<span color='#ffead3'><b>{}</b></span>",
                "days": "<span color='#ecc6d9'><b>{}</b></span>",
                "weeks": "<span color='#99ffdd'><b>W{:%V}</b></span>",
                "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
                "today": "<span color='#ff6699'><b><u>{}</u></b></span>"
            }
        }
    },
    "custom/weather": {
        "format": "{}",
        "format-alt": "{alt}: {}",
        "format-alt-click": "click",
        "interval": 3600,
        "return-type": "json",
        //"exec": "$HOME/.config/hypr/UserScripts/Weather.py",
        //"exec": "$HOME/.config/hypr/UserScripts/Weather.sh",
        "exec": "$HOME/.config/hypr/UserScripts/WeatherWrap.sh",
        //"exec-if": "ping wttr.in -c1",
        "tooltip": true,
    },
    "battery": {
        "states": { "warning": 30, "critical": 15 },
        "format": "{icon} {capacity}%",
        "format-icons": ["пү„", "пүғ", "пүӮ", "пүҒ", "пүҖ"]
    },

    "custom/power": {
        "format": "вҸ»", // Puedes usar "пҖ‘ " si tienes Nerd Fonts instalada
        "on-click": "wlogout", // O la ruta a tu script: "~/.config/hypr/scripts/Wlogout.sh"
        "tooltip": "Logout menu"
    },
    "hyprland/workspaces#rw": {
        "disable-scroll": true,
        "all-outputs": true,
        "warp-on-scroll": false,
        "sort-by-number": true,
        "show-special": false,
        "on-click": "activate",
        "on-scroll-up": "hyprctl dispatch workspace e+1",
        "on-scroll-down": "hyprctl dispatch workspace e-1",
        "persistent-workspaces": {
            "*": 5
        },
        "format": "{icon} {windows}",
        "format-window-separator": " ",
        "window-rewrite-default": "пҒҷ ",
        "window-rewrite": {		
            "title<.*amazon.*>": "пү° ",
            "title<.*reddit.*>": "пҠҒ ",

            "class<firefox|org.mozilla.firefox|librewolf|floorp|mercury-browser|[Cc]achy-browser>": "оқ… ",
            "class<zen>": "у°°· ",
            "class<waterfox|waterfox-bin>": "оә“ ",
            "class<microsoft-edge>": "пҠӮ ",
            "class<Chromium|Thorium|[Cc]hrome>": "пүЁ ",
            "class<brave-browser>": "рҹҰҒ ",
            "class<tor browser>": "пҚұ ",
            "class<firefox-developer-edition>": "рҹҰҠ ",

            "class<kitty|konsole|[Aa]lacritty>": "оҜҶ ",
            "class<kitty-dropterm>": "п„  ",
            "class<com.mitchellh.ghostty>": " оһ•",
            "class<org.wezfurlong.wezterm>": " оӘ…",
            "class<Warp|warp|dev.warp.Warp|warp-terminal>": "у°°ӯ ",

            "class<[Tt]hunderbird|[Tt]hunderbird-esr>": "пҚ° ",
            "class<eu.betterbird.Betterbird>": "пҚ° ",
            "title<.*gmail.*>": "у°Ҡ« ",

            "class<[Tt]elegram-desktop|org.telegram.desktop|io.github.tdesktop_x64.TDesktop>": "оҲ— ",
            "class<discord|discord-canary|[Ww]ebcord|[Vv]esktop|com.discordapp.Discord|dev.vencord.Vesktop>": "пҮҝ ",
            "class<[Ss]ignal|signal-desktop|org.signal.Signal>": "у°Қ© ",
            "title<.*Signal.*>": "у°Қ© ",
            "title<.*whatsapp.*>": "пҲІ ",
            "title<.*zapzap.*>": "пҲІ ",
            "title<.*messenger.*>": "пүҹ ",
            "title<.*facebook.*>": "пӮҡ ",
            "title<.*Discord.*>": "пҮҝ ",

            "title<.*ChatGPT.*>": "у°ҡ© ",
